# Private Space Configuration
private_space_id = "your-private-space-id"

# PEM Certificate Configuration
pem_certificate = <<-EOF-----BEGIN CERTIFICATE-----
# Anypoint Platform credentials
anypoint_client_id     = "your-client-id"
anypoint_client_secret = "your-client-secret"
anypoint_base_url      = "https://anypoint.mulesoft.com"

# Private space configuration
private_space_name = "test-tls-private-space"
private_space_region = "us-east-1"

# TLS context configuration
tls_context_name = "test-tls-context"

# Certificate configuration (PEM format)
# Replace these with your actual certificates
certificate_pem = <<-EOT
-----BEGIN CERTIFICATE-----
MIIFATCCAumgAwIBAgIRALHinJlCMDuPqtBHAZWASJMwDQYJKoZIhvcNAQELBQAw
...your certificate content here...
-----END CERTIFICATE-----
EOT

private_key_pem = <<-EOT
-----BEGIN PRIVATE KEY-----
MIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQC8...
...your private key content here...
-----END PRIVATE KEY-----
EOT

ca_certificate_pem = <<-EOT
-----BEGIN CERTIFICATE-----
MIIFxTCCA62gAwIBAgIUNJ3zSJCLgftSLT4rrpINfOQHoL8wDQYJKoZIhvcNAQEL
...your CA certificate content here...
-----END CERTIFICATE-----
EOT

# Optional: Private key passphrase (if your key is encrypted)
key_passphrase = ""

# Trust store configurations (PEM format)
trust_store_pem_1 = <<-EOT
-----BEGIN CERTIFICATE-----
MIIFxTCCA62gAwIBAgIUNJ3zSJCLgftSLT4rrpINfOQHoL8wDQYJKoZIhvcNAQEL
...your first trust store certificate content here...
-----END CERTIFICATE-----
EOT

trust_store_pem_2 = <<-EOT
-----BEGIN CERTIFICATE-----
MIIFATCCAumgAwIBAgIRALHinJlCMDuPqtBHAZWASJMwDQYJKoZIhvcNAQELBQAw
...your second trust store certificate content here...
-----END CERTIFICATE-----
EOT

# Additional TLS configuration variables can be added here as needed 