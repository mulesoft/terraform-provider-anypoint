# Anypoint Platform credentials
anypoint_client_id     = "your-client-id"
anypoint_client_secret = "your-client-secret"
anypoint_base_url      = "https://anypoint.mulesoft.com"

# Private Space Configuration
private_space_id = "your-private-space-id"

# VPN Connection Data Source Configuration
vpn_connection_id = "your-vpn-connection-id"

# VPN Connection Configuration
connection_name = "example-vpn-connection"

# VPN Configuration
local_asn         = "64512"
remote_asn        = "65001"
remote_ip_address = "204.12.238.216"

# VPN Tunnel Configuration
psk_1      = "your-psk-1"
psk_2      = "your-psk-2"
ptp_cidr_1 = "169.254.1.0/30"
ptp_cidr_2 = "169.254.2.0/30"

startup_action = "start" 