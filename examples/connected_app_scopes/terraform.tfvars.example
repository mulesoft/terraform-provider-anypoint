# Copy this file to terraform.tfvars and fill in your values
# Note: All variables have defaults, so this file is optional

# Admin user authentication credentials (required for connected_app_scopes)
anypoint_admin_client_id     = "<anypoint_admin_client_id>"
anypoint_admin_client_secret = "<anypoint_admin_client_secret>"
anypoint_admin_username      = "<admin_username_here>"
anypoint_admin_password      = "<admin_password_here>"

# Platform configuration
anypoint_base_url = "https://stgx.anypoint.mulesoft.com"

# Connected app to manage
connected_app_id = "<anypoint_connected_app_client_id>"

# Target organization for scopes
target_organization_id = "<org_id>"