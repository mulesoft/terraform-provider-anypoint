# Copy this file to terraform.tfvars and fill in your values
# Note: Provider credentials have defaults, so you only need to override if using different values

# ─────────────────────────────────────────────────────────────
# Provider Configuration (Optional - defaults provided)
# ─────────────────────────────────────────────────────────────

# anypoint_client_id     = "<anypoint_connected_app_client_id>"
# anypoint_client_secret = "<anypoint_connected_app_client_secret>"
# anypoint_base_url      = "https://stgx.anypoint.mulesoft.com"

# ─────────────────────────────────────────────────────────────
# Resource Configuration (Required)
# ─────────────────────────────────────────────────────────────

# Organization ID (Optional - has default)
# organization_id = "<org_id>"

# Environment ID where your API is deployed (Required)
environment_id = "your-environment-id-here"

# API Instance ID - The numeric ID of your API instance (Required)
# You can find this in API Manager → Your API → Copy from URL
# Example: https://anypoint.mulesoft.com/apimanager/api/v1/organizations/.../environments/.../apis/12345678
api_instance_id = "12345678"
