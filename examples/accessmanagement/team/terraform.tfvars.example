# Copy this file to terraform.tfvars and update with your actual values
# Example: cp terraform.tfvars.example terraform.tfvars

# Anypoint Platform Credentials
anypoint_client_id     = "your-actual-client-id-here"
anypoint_client_secret = "your-actual-client-secret-here"

# Anypoint Platform URL
anypoint_base_url = "https://anypoint.mulesoft.com"  # Production
# anypoint_base_url = "https://stgx.anypoint.mulesoft.com"  # Staging

# Team Configuration
org_id         = "your-organization-id-here"
parent_team_id = "your-parent-team-id-here"  # Use organization ID for root team
